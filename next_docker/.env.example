# --- MySQL ---
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=crud_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# --- Frontend ---
# This value is baked into the Next.js build at build time (NEXT_PUBLIC_*),
# because the browser calls this URL directly (not through the Docker network).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Host port for the frontend container. Change this if 3000 is already in
# use on your machine (the container itself always listens on 3000).
FRONTEND_PORT=3000

# --- phpMyAdmin (web-based MySQL admin UI) ---
# Host port to open phpMyAdmin in the browser. Change this if 8080 is already
# in use on your machine (the container itself always listens on 80).
PHPMYADMIN_PORT=8080
